# Python
__pycache__/
*.py[cod]
.pytest_cache/

# Cache-warmer runtime markers + validation dirty-flag (session-local, transient)
.claude/cache-warmer.*.active
.claude/validate-refs.dirty

# Acquired full-text sources: PDFs are tracked via Git LFS (see .gitattributes).
# Still ignore any other (non-PDF) contents of download/.
download/*
!download/.gitkeep
!download/*.pdf

# Node (viewer server deps; install via `cd viewer && npm install`)
node_modules/

# Viewer test/deploy artifacts (Playwright + multi-root publish bundle)
viewer/test-results/
viewer/playwright-report/
viewer/dist/

# Viewer-generated local reader state (per-user highlight annotations,
# keyed to a document revision — machine-local, not shared)
.viewer-highlights/

# OS / editor
.DS_Store
*.swp
