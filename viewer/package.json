{
  "name": "llm-zero-to-one-viewer",
  "version": "1.0.0",
  "private": true,
  "description": "Local markdown viewer for surveys/ (serve.js + client bundle). Ported from data-channel-receiver/viewer.",
  "type": "commonjs",
  "main": "viewer.js",
  "scripts": {
    "start": "node serve.js",
    "test": "npm run test:unit && playwright test",
    "test:unit": "node --test \"tests/unit/**/*.test.js\"",
    "test:e2e": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "check-vendor": "node tools/check-vendor.js",
    "publish": "node publish.js",
    "pull-annotations": "node pull-annotations.js pull",
    "push-annotations": "node pull-annotations.js push"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chokidar": "^4.0.0",
    "ignore": "^7.0.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "wrangler": "^4.98.0"
  }
}
